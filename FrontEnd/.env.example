# ─── ARISE / LearnForEarn — Environment Variables ─────────────────────────────
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Vercel: set these in Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (Spring Boot)
# Local:      http://localhost:8080/api
# Test:       https://learntoearn-wnpp.onrender.com/api
# Production: https://learnforearn.onrender.com/api
VITE_API_URL=https://your-backend-url.com/api

# Google OAuth Web Client ID (public — safe to expose in the bundle).
# Get it from Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web).
# Must match the backend GOOGLE_CLIENT_ID. Leave blank to hide the Google button.
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# GitHub profile connect is server-side OAuth — no frontend env vars needed.
# Backend (Render): GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET, BACKEND_PUBLIC_URL,
# APP_URL (frontend origin, e.g. https://learnforearn.in), CORS_ALLOWED_ORIGINS.

# ⚠️  SECURITY NOTE:
# All VITE_ variables are PUBLIC — they are embedded in the browser bundle.
# Never put API keys, tokens, passwords, or secrets here.
# Sensitive config belongs in the backend environment only.
